# .env.example — Copia questo file in .env e compila con i valori reali.
# Il file .env NON deve essere committato (vedi .gitignore).

# URL completo del Web Service SOAP del magazzino Hanel t-Server
# Esempio: http://192.168.1.100:8080/HanelService
HANEL_ENDPOINT_URL=http://<host>:<port>/HanelService

# Modalità test: se true, il prefisso viene anteposto automaticamente a ogni
# jobNumber inviato, permettendo agli operatori di identificare gli ordini di test.
HANEL_TEST_MODE=false

# Prefisso usato in modalità test (default: TEST_)
HANEL_TEST_PREFIX=TEST_

# Abilita le operazioni SOAP V02/V03/V04 con supporto numero lotto (batch_number).
# Quando false (default), vengono usate le operazioni V01 — retrocompatibilità totale.
HANEL_LOT_MANAGEMENT_ENABLED=false
